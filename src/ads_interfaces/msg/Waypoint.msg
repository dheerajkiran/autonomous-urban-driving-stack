# Waypoint.msg
# A single navigable point on the road network.
# Generated by route_planner from OpenStreetMap data.

float64 latitude        # WGS84 latitude [degrees]
float64 longitude       # WGS84 longitude [degrees]
float64 x               # SUMO projected x coordinate [m]
float64 y               # SUMO projected y coordinate [m]
int64 osmid             # OpenStreetMap node ID
float64 speed_limit     # Posted speed limit at this point [m/s]
string road_name        # Street name (e.g. "Mill Ave", "University Dr")
